{
  "info": {
    "_postman_id": "8b2f9646-cc63-4d91-b35b-a2d4d8243ba7",
    "name": "Restful-Booker API Testing",
    "description": "API testing collection for Restful-Booker: auth, create, read, update, delete, and validation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://restful-booker.herokuapp.com"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "bookingId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "API-001 Healthcheck Ping",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is successful', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test('Body contains Created', function () {",
              "  pm.expect(pm.response.text()).to.include('Created');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/ping",
          "host": ["{{baseUrl}}"],
          "path": ["ping"]
        }
      }
    },
    {
      "name": "API-002 Create Auth Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const response = pm.response.json();",
              "pm.test('Token exists', function () {",
              "  pm.expect(response.token).to.be.a('string').and.not.empty;",
              "});",
              "pm.collectionVariables.set('token', response.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth",
          "host": ["{{baseUrl}}"],
          "path": ["auth"]
        }
      }
    },
    {
      "name": "API-003 Create Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const response = pm.response.json();",
              "pm.test('Booking id is returned', function () {",
              "  pm.expect(response.bookingid).to.be.a('number');",
              "});",
              "",
              "pm.test('Created booking has expected firstname', function () {",
              "  pm.expect(response.booking.firstname).to.eql('Thanh');",
              "});",
              "pm.collectionVariables.set('bookingId', response.bookingid);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstname\": \"Thanh\",\n  \"lastname\": \"Nguyen\",\n  \"totalprice\": 150,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-07-01\",\n    \"checkout\": \"2026-07-05\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/booking",
          "host": ["{{baseUrl}}"],
          "path": ["booking"]
        }
      }
    },
    {
      "name": "API-004 Get Created Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const response = pm.response.json();",
              "pm.test('Booking data matches created booking', function () {",
              "  pm.expect(response.firstname).to.eql('Thanh');",
              "  pm.expect(response.lastname).to.eql('Nguyen');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/booking/{{bookingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["booking", "{{bookingId}}"]
        }
      }
    },
    {
      "name": "API-005 Update Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const response = pm.response.json();",
              "pm.test('Booking is updated', function () {",
              "  pm.expect(response.firstname).to.eql('Thanh Updated');",
              "  pm.expect(response.totalprice).to.eql(220);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "token={{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstname\": \"Thanh Updated\",\n  \"lastname\": \"Nguyen\",\n  \"totalprice\": 220,\n  \"depositpaid\": false,\n  \"bookingdates\": {\n    \"checkin\": \"2026-07-02\",\n    \"checkout\": \"2026-07-06\"\n  },\n  \"additionalneeds\": \"Late checkout\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/booking/{{bookingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["booking", "{{bookingId}}"]
        }
      }
    },
    {
      "name": "API-006 Delete Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is successful delete response', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "token={{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/booking/{{bookingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["booking", "{{bookingId}}"]
        }
      }
    },
    {
      "name": "API-007 Verify Deleted Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Deleted booking is not found', function () {",
              "  pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/booking/{{bookingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["booking", "{{bookingId}}"]
        }
      }
    }
  ]
}

